{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ConvertIT",
  "version": "0.1.0",
  "identifier": "com.convertit.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "corepack pnpm dev",
    "beforeBuildCommand": "corepack pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ConvertIT",
        "width": 1140,
        "height": 880,
        "minWidth": 780,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": [
      "../vendor/bin/*"
    ]
  }
}